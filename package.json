{
  "name": "@onlynative/game-engine",
  "version": "0.0.0-1.alpha",
  "description": "2D (and soon 3D) game engine for React Native + Expo Go. Skia-based renderer, ECS core, fixed-timestep loop, no native code.",
  "keywords": [
    "expo",
    "expo-go",
    "react-native",
    "game-engine",
    "ecs",
    "skia",
    "reanimated",
    "2d"
  ],
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./renderers/skia": {
      "types": "./dist/renderers/skia/index.d.ts",
      "react-native": "./src/renderers/skia/index.ts",
      "import": "./dist/renderers/skia/index.js",
      "default": "./dist/renderers/skia/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:llms": "node scripts/build-llms-full.mjs",
    "typecheck": "tsc --noEmit && pnpm --filter example typecheck",
    "prepack": "pnpm build && pnpm build:llms",
    "start": "pnpm --filter example start",
    "ios": "pnpm --filter example ios",
    "android": "pnpm --filter example android",
    "web": "pnpm --filter example web"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.2.0",
    "expo-asset": ">=12.0.0",
    "expo-file-system": ">=19.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-gesture-handler": ">=2.28.0",
    "react-native-reanimated": ">=4.1.0",
    "react-native-worklets": ">=0.5.0"
  },
  "devDependencies": {
    "@shopify/react-native-skia": "2.2.12",
    "@types/react": "~19.1.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-file-system": "~19.0.22",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2"
  }
}
